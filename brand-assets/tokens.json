{
  "$meta": {
    "brand": "Sevyn8",
    "system": "Spectrum Intelligence",
    "version": "4.0",
    "rules": [
      "Ion is the only hue on chrome & CTAs.",
      "Cyan is for live/active states only.",
      "Magenta is for highlights & data-viz only — never a button or background.",
      "The spectrum gradient is logo-only — never a fill.",
      "Support dark (ink) and light (paper) from the same tokens.",
      "Never set body text in a brand hue."
    ]
  },
  "roles": { "hero": "ion", "signal": "cyan", "highlight": "magenta", "spectrum": "logo-only", "modes": ["dark", "light"] },
  "color": {
    "brand": {
      "ion": "#414BF5",
      "ionHover": "#2F38D6",
      "cyan": "#19D3E0",
      "magenta": "#E63DCB"
    },
    "gradient": { "spectrum": "linear-gradient(135deg, #19D3E0 0%, #414BF5 50%, #E63DCB 100%)" },
    "ramps": {
      "ion":     { "50":"#EEF0FE","100":"#DDE0FD","200":"#BAC0FB","300":"#8E97F8","400":"#6470F6","500":"#414BF5","600":"#2F38D6","700":"#232BAA","800":"#1B2080","900":"#141659" },
      "cyan":    { "50":"#E5FBFC","100":"#C9F5F8","200":"#97ECF1","300":"#5FE0E9","400":"#2FD7E3","500":"#19D3E0","600":"#10A9B4","700":"#0E848C","800":"#0C666C","900":"#0A4A4F" },
      "magenta": { "50":"#FDEAF9","100":"#FAD0F2","200":"#F5A6E6","300":"#EF74D7","400":"#EA4FCE","500":"#E63DCB","600":"#BE1FA6","700":"#971681","800":"#711161","900":"#4E0C43" }
    },
    "neutral": {
      "white":"#FFFFFF","paper":"#F4F6FA","n100":"#E7EAF1","n200":"#D2D7E2","n300":"#AEB5C6",
      "n400":"#7E8699","slate":"#5A6275","n600":"#3C4354","n700":"#272D3B","n800":"#181C28","ink":"#0B0D14"
    },
    "semantic": { "success":"#2BD97A", "warning":"#FFB020", "danger":"#FF4D5E", "info":"#4DA3FF" }
  },
  "font": {
    "sans": "IBM Plex Sans",
    "mono": "IBM Plex Mono",
    "scale": {
      "display": { "size": "3.5rem", "weight": 600, "tracking": "-0.03em", "leading": 1.05 },
      "h1": { "size": "2.5rem", "weight": 600, "tracking": "-0.03em", "leading": 1.1 },
      "h2": { "size": "1.75rem", "weight": 600, "tracking": "-0.02em", "leading": 1.15 },
      "h3": { "size": "1.25rem", "weight": 600, "tracking": "-0.01em", "leading": 1.2 },
      "bodyLg": { "size": "1.1875rem", "weight": 400, "leading": 1.6 },
      "body": { "size": "1rem", "weight": 400, "leading": 1.6 },
      "small": { "size": "0.875rem", "weight": 400, "leading": 1.5 },
      "label": { "size": "0.75rem", "weight": 500, "tracking": "0.14em", "transform": "uppercase", "font": "mono" }
    }
  },
  "space": { "1":4, "2":8, "3":12, "4":16, "5":24, "6":32, "7":48, "8":64, "9":96 },
  "radius": { "sm":8, "md":14, "lg":20, "pill":999 },
  "elevation": {
    "e1": "0 1px 2px rgba(11,13,20,.06)",
    "e2": "0 4px 16px rgba(11,13,20,.08)",
    "e3": "0 12px 40px rgba(11,13,20,.12)"
  }
}
